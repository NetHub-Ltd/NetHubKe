{
  "realm": "nethub",
  "enabled": true,
  "displayName": "Nethub Kenya",
  "sslRequired": "external",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "rememberMe": true,
  "verifyEmail": true,
  "resetPasswordAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,

  "passwordPolicy": "length(8) and upperCase(1) and lowerCase(1) and digits(1) and specialChars(1) and notUsername() and notEmail()",

  "bruteForceDetectorEnabled": true,
  "failureFactor": 5,
  "waitIncrementSeconds": 60,
  "maxFailureWaitSeconds": 900,
  "maxDeltaTimeSeconds": 43200,
  "quickLoginCheckMilliSeconds": 1000,
  "minimumQuickLoginWaitSeconds": 60,

  "smtpServer": {
    "host": "smtp.gmail.com",
    "port": "587",
    "from": "nethubdigitalsolutions@gmail.com",
    "fromDisplayName": "Nethub Support",
    "auth": "true",
    "ssl": "false",
    "starttls": "true",
    "user": "nethubdigitalsolutions@gmail.com",
    "password": "mkja gqft xthb kjju",
    "replyTo": "nethubdigitalsolutions@gmail.com"
  },

  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Standard authenticated user"
      },
      {
        "name": "admin",
        "description": "Administrator with elevated privileges",
        "composite": true,
        "composites": {
          "client": {
            "realm-management": [
              "manage-users",
              "query-users",
              "view-users",
              "manage-clients",
              "view-clients"
            ]
          }
        }
      }
    ]
  },

  "groups": [
    {
      "name": "nethub-admins",
      "path": "/nethub-admins",
      "realmRoles": ["admin"]
    },
    {
      "name": "nethub-users",
      "path": "/nethub-users",
      "realmRoles": ["user"]
    }
  ],

  "defaultGroups": ["/nethub-users"],

  "clientScopes": [
    {
      "name": "api",
      "description": "Nethub API Scopes",
      "protocol": "openid-connect",
      "attributes": {
        "display.on.consent.screen": "true",
        "consent.screen.text": "Access to Nethub API"
      },
      "protocolMappers": [
        {
          "name": "api-read",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "config": {
            "claim.name": "scope",
            "claim.value": "user:read",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        },
        {
          "name": "api-write",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "config": {
            "claim.name": "scope",
            "claim.value": "user:write",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "name": "roles",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "true"
          }
        }
      ]
    }
  ],

  "clients": [
    {
      "clientId": "nethub-frontend",
      "name": "Nethub Web Frontend",
      "enabled": true,
      "publicClient": true,
      "redirectUris": [
        "https://nethub.co.ke/*",
        "https://www.nethub.co.ke/*",
        "http://localhost:3000/*"
      ],
      "webOrigins": ["+"],
      "standardFlowEnabled": true,
      "fullScopeAllowed": false,
      "defaultClientScopes": ["openid", "profile", "email", "roles"],
      "optionalClientScopes": ["api"]
    },
    {
      "clientId": "nethub-backend",
      "name": "Nethub FastAPI Backend",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "REPLACE_WITH_STRONG_BACKEND_SECRET_64_CHARS",
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "fullScopeAllowed": false,
      "defaultClientScopes": ["roles"]
    }
  ]
}
