{
  "realm": "nethub",
  "enabled": true,
  "sslRequired": "external",

  "registrationAllowed": true,
  "resetPasswordAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "registrationEmailAsUsername": true,
  "rememberMe": true,

  "displayName": "Nethub Kenya",
  "verifyEmail": true,

  "passwordPolicy": "length(12) and notUsername and notEmail",

  "smtpServer": {
    "host": "smtp.gmail.com",
    "port": "587",
    "from": "nethubdigitalsolutions@gmail.com",
    "fromDisplayName": "Nethub Support",
    "auth": "true",
    "ssl": "false",
    "starttls": "true",
    "user": "nethubdigitalsolutions@gmail.com",
    "password": "mkja gqft xthb kjju",
    "replyTo": "nethubdigitalsolutions@gmail.com"
  },

  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Standard authenticated user"
      },
      {
        "name": "admin",
        "description": "Administrator with elevated privileges",
        "composite": true,
        "composites": {
          "client": {
            "realm-management": [
              "manage-users",
              "query-users",
              "view-users",
              "manage-clients",
              "view-clients"
            ]
          }
        }
      }
    ]
  },

  "groups": [
    {
      "name": "nethub-admins",
      "path": "/nethub-admins",
      "realmRoles": ["admin"],
      "clientRoles": {},
      "subGroups": []
    },
    {
      "name": "nethub-users",
      "path": "/nethub-users",
      "realmRoles": ["user"],
      "clientRoles": {},
      "subGroups": []
    }
  ],

  "defaultGroups": ["/nethub-users"],

  "clients": [
    {
      "clientId": "nethub-frontend",
      "name": "Nethub Web Frontend",
      "enabled": true,
      "publicClient": true,

      "redirectUris": [
        "https://nethub.co.ke/*",
        "https://www.nethub.co.ke/*",
        "http://localhost:3000/*"
      ],

      "webOrigins": ["+"],
      "fullScopeAllowed": false,

      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,

      "defaultClientScopes": ["roles", "groups", "openid", "profile", "email"]
    },

    {
      "clientId": "nethub-backend",
      "name": "Nethub FastAPI Backend",
      "enabled": true,

      "clientAuthenticatorType": "client-secret",
      "secret": "REPLACE_WITH_STRONG_BACKEND_SECRET_64_CHARS",

      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": true,

      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,

      "fullScopeAllowed": false,
      "defaultClientScopes": ["roles", "groups"]
    }
  ],

  "clientScopes": [
    {
      "name": "roles",
      "description": "Adds user roles to access and ID tokens",
      "protocol": "openid-connect",
      "attributes": {
        "display.on.consent.screen": "true",
        "consent.screen.text": "User roles"
      },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "true"
          }
        }
      ]
    },

    {
      "name": "groups",
      "description": "Adds user group membership to tokens",
      "protocol": "openid-connect",
      "attributes": {
        "display.on.consent.screen": "true",
        "consent.screen.text": "Group membership"
      },
      "protocolMappers": [
        {
          "name": "group mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "full.path": "false",
            "claim.name": "groups",
            "access.token.claim": "true",
            "id.token.claim": "true"
          }
        }
      ]
    },

    {
      "name": "openid",
      "protocol": "openid-connect",
      "attributes": {
        "display.on.consent.screen": "false"
      }
    },

    {
      "name": "profile",
      "protocol": "openid-connect",
      "attributes": {
        "display.on.consent.screen": "true",
        "consent.screen.text": "User profile information"
      },
      "protocolMappers": [
        {
          "name": "preferred_username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        },
        {
          "name": "given_name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "user.attribute": "firstName",
            "claim.name": "given_name",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        },
        {
          "name": "family_name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "user.attribute": "lastName",
            "claim.name": "family_name",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        },
        {
          "name": "name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-full-name-mapper",
          "config": {
            "claim.name": "name",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        },
        {
          "name": "email_verified",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "user.attribute": "emailVerified",
            "claim.name": "email_verified",
            "jsonType.label": "boolean",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    },

    {
      "name": "email",
      "protocol": "openid-connect",
      "attributes": {
        "display.on.consent.screen": "true",
        "consent.screen.text": "User email address"
      },
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "user.attribute": "email",
            "claim.name": "email",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ]
}
